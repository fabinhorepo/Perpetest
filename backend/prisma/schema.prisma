// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ CUSTOMER & PROJECT DOMAIN ============

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  document  String   @unique // CPF or CNPJ
  type      String   // "PF" (pessoa física), "PJ" (empresa), "GOVERNMENT"
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  projects  Project[]
  carts     Cart[]
  orders    Order[]

  @@index([email])
  @@index([document])
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  street     String
  number     String
  complement String?
  city       String
  state      String
  zipCode    String
  country    String @default("BR")
  isDefault  Boolean @default(false)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
}

model Project {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  biome       String   // "Cerrado", "Mata Atlântica", "Amazônia", etc.
  soilType    String?  // "Argiloso", "Arenoso", etc.
  areaSizeHa  Float    // Área em hectares
  objective   String   // "APP" (Área de Proteção Permanente), "RL" (Reserva Legal), "Enriquecimento", "Paisagismo"
  
  // Geo info (simplified)
  latitude    Float?
  longitude   Float?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  carts       Cart[]
  orders      Order[]
  orderItems  OrderItem[]

  @@index([customerId])
  @@index([biome])
  @@index([objective])
}

// ============ CATALOG DOMAIN ============

model Species {
  id                String   @id @default(cuid())
  scientificName    String   @unique
  commonName        String
  biome             String   // Primary biome
  ecologicalGroup   String   // "Pioneira", "Secundária", "Clímax"
  growthSpeedMonths Int      // Months to reach harvestable size
  shadeTolerance    String   // "Pleno sol", "Meia sombra", "Sombra"
  notes             String?
  photoUrl          String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  batches           Batch[]
  products          Product[]
  bundleItems       BundleItem[]

  @@index([biome])
  @@index([ecologicalGroup])
}

model Batch {
  id               String   @id @default(cuid())
  speciesId        String
  species          Species  @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  
  nurseryLocation  String   // e.g., "Viveiro Principal - Setor A"
  productionDate   DateTime
  readyFromDate    DateTime
  readyToDate      DateTime
  totalSeedlings   Int
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  stocks           NurseryStock[]

  @@index([speciesId])
  @@index([readyFromDate])
}

model Product {
  id          String   @id @default(cuid())
  speciesId   String
  species     Species  @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  
  displayName String
  description String?
  photoUrl    String?
  basePrice   Float    // Base price in BRL
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems   CartItem[]
  orderItems  OrderItem[]
  priceEntry  PriceEntry[]

  @@index([speciesId])
}

model Bundle {
  id              String   @id @default(cuid())
  name            String
  description     String?
  targetBiome     String   // Recommended for which biome
  targetObjective String   // "APP", "RL", etc.
  photoUrl        String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           BundleItem[]
  cartItems       CartItem[]

  @@index([targetBiome])
}

model BundleItem {
  id        String @id @default(cuid())
  bundleId  String
  bundle    Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  speciesId String
  species   Species @relation(fields: [speciesId], references: [id])
  
  percentageQty Float // Percentage of total seedlings for this species
  
  @@unique([bundleId, speciesId])
  @@index([bundleId])
}

// ============ INVENTORY DOMAIN ============

model NurseryStock {
  id               String   @id @default(cuid())
  batchId          String
  batch            Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  availableQty     Int
  reservedQty      Int      @default(0)
  
  updatedAt        DateTime @updatedAt

  reservations     Reservation[]

  @@unique([batchId])
  @@index([batchId])
}

model Reservation {
  id           String   @id @default(cuid())
  stockId      String
  stock        NurseryStock @relation(fields: [stockId], references: [id], onDelete: Cascade)
  
  orderId      String?  // Links to order once placed
  quantity     Int
  expiresAt    DateTime
  status       String   @default("ACTIVE") // "ACTIVE", "CONFIRMED", "RELEASED"
  
  createdAt    DateTime @default(now())

  @@index([stockId])
  @@index([orderId])
}

// ============ PRICING DOMAIN ============

model PriceList {
  id         String   @id @default(cuid())
  name       String   @unique
  validFrom  DateTime
  validTo    DateTime?
  isDefault  Boolean  @default(false)
  
  createdAt  DateTime @default(now())

  entries    PriceEntry[]

  @@index([isDefault])
}

model PriceEntry {
  id           String   @id @default(cuid())
  priceListId  String
  priceList    PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  bundleId     String?
  
  unitPrice    Float
  minQty       Int      @default(1)
  maxQty       Int?
  
  createdAt    DateTime @default(now())

  @@index([priceListId])
  @@index([productId])
}

model Promotion {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String   // "PERCENT" or "AMOUNT"
  discountValue Float
  validFrom     DateTime
  validTo       DateTime
  isActive      Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============ CART DOMAIN ============

model Cart {
  id        String   @id @default(cuid())
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     CartItem[]

  @@unique([customerId, projectId])
  @@index([customerId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  bundleId  String?
  bundle    Bundle?  @relation(fields: [bundleId], references: [id], onDelete: SetNull)
  
  quantity  Int
  createdAt DateTime @default(now())

  @@index([cartId])
  @@check("(productId IS NOT NULL AND bundleId IS NULL) OR (productId IS NULL AND bundleId IS NOT NULL)")
}

// ============ ORDER DOMAIN ============

model Order {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  status        String   @default("NEW") // NEW, RESERVED, IN_PRODUCTION, READY_FOR_SHIPMENT, ON_ROUTE, DELIVERED, CANCELLED
  totalAmount   Float
  freightCost   Float    @default(0)
  freightMethod String?  // "ECONOMICAL", "EXPRESS", "DEDICATED"
  
  // Delivery info
  deliveryAddress String?
  deliveryLat     Float?
  deliveryLon     Float?
  deliveryWindowStart DateTime?
  deliveryWindowEnd   DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         OrderItem[]
  payment       Payment?
  history       OrderStatusHistory[]

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  bundleId  String?
  
  quantity  Int
  unitPrice Float
  totalPrice Float
  
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  status    String
  reason    String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

// ============ PAYMENT DOMAIN ============

model Payment {
  id            String   @id @default(cuid())
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  method        String   // "PIX", "CARD", "BOLETO"
  status        String   @default("PENDING") // PENDING, APPROVED, FAILED, REFUNDED
  transactionId String?
  amount        Float
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
}

// ============ DELIVERY DOMAIN ============

model Vehicle {
  id             String   @id @default(cuid())
  name           String
  capacityVolume Float    // Liters
  capacityWeight Float    // kg
  isActive       Boolean  @default(true)
  
  createdAt      DateTime @default(now())

  routes         Route[]
}

model Route {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  
  routeDate DateTime
  status    String   @default("PLANNED") // PLANNED, STARTED, COMPLETED
  
  createdAt DateTime @default(now())

  stops     Stop[]
}

model Stop {
  id              String   @id @default(cuid())
  routeId         String
  route           Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  orderId         String
  sequence        Int
  eta             DateTime?
  status          String   @default("PENDING") // PENDING, DONE
  
  @@unique([routeId, orderId])
  @@index([routeId])
}
